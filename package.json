{
  "name": "ng-component-graph",
  "version": "0.2.0",
  "description": "Draw the full hierarchy of a standalone Angular app — app → route → page component → child component — reconstructed from *.routes.ts and @Component imports[] via the TypeScript AST, rendered with graphviz.",
  "type": "module",
  "bin": {
    "ng-component-graph": "./component-graph.mjs",
    "ng-nav-audit": "./nav-audit.mjs"
  },
  "main": "./component-graph.mjs",
  "files": [
    "component-graph.mjs",
    "nav-audit.mjs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "graph": "node component-graph.mjs",
    "audit": "node nav-audit.mjs",
    "test": "node test/smoke.mjs",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "angular",
    "standalone",
    "component",
    "graph",
    "routes",
    "route-tree",
    "dependency-graph",
    "graphviz",
    "dead-code",
    "orphan",
    "ast"
  ],
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "typescript": ">=4.5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": false
    }
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "author": "Ignikah <hello@ignikah.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ignikah-dev/ng-component-graph.git"
  },
  "homepage": "https://github.com/ignikah-dev/ng-component-graph#readme",
  "bugs": {
    "url": "https://github.com/ignikah-dev/ng-component-graph/issues"
  }
}
